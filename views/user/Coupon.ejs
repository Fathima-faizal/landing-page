<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VisionVogue - Profile</title>
    <link rel="stylesheet" href="/css/coupons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>

    <header class="navbar">
        <nav class="nav-links">
            <a href="/home">Home</a>
            <a href="/shop">shop</a>
            <a href="#">About</a>
            <a href="#">Contact us</a>
        </nav>
        <div class="logo">VisionVogue</div>
        <div class="nav-icons">
             <a href="/wishlist" ><i class="fa-regular fa-heart"></i></a>
               <a href="/cart"> <i class="fa-solid fa-cart-shopping"></i></a>
              <a href="/profile" > <i class="fa-regular fa-user"></i></a>
    </header>

    <main class="profile-container">
        <h1>Coupon</h1>
        
        <div class="content-wrapper">
            <aside class="sidebar">
                <h3>My Account</h3>
                <ul>
                   <a href="/profile"><li >Profile</li></a>
                   <a href="/address"> <li>Address</li> </a>
                   <a href="/order"><li>Order</li> </a>
                   <a href="/wallet"><li>Wallet</li> </a>
                   <a href="/Coupon"> <li class="active">Coupon</li> </a>
                   <a href="/refer" ><li>Refer & Earn</li> </a>
                   <a href="/password"><li>Change Password</li> </a>
                   <a href="/logout"><li>Log out</li> </a>
                </ul>
            </aside>
            <section>
            <div class="coupon-grid">
        <% if (coupons.length > 0) { %>
            <% coupons.forEach(coupon => { %>
                <div class="coupon-card">
                    <div class="coupon-left">
                        <div class="discount-box">
                            <span class="amount">
                                <%= coupon.couponType === 'percentage' ? coupon.discountPercentage + '%' : '₹' + coupon.discountPercentage %>
                            </span>
                            <span class="off-text">OFF</span>
                        </div>
                        <p class="min-spend">Min Spend: ₹<%= coupon.minimumPrice %></p>
                        <div class="notch notch-top"></div>
                        <div class="notch notch-bottom"></div>
                    </div>

                    <div class="coupon-right">
                        <div class="coupon-info">
                            <h4 class="coupon-name"><%= coupon.name %></h4>
                            <p class="coupon-expiry">
                                <i class="fa-regular fa-clock"></i> Expires: <%= new Date(coupon.expireOn).toLocaleDateString() %>
                            </p>
                        </div>
                        <div class="code-container">
                            <div class="code-box">
                                <span class="code-text" id="code-<%= coupon._id %>"><%= coupon.couponCode %></span>
                            </div>
                            <button class="copy-btn" onclick="copyCode('<%= coupon._id %>')">
                                <i class="fa-regular fa-copy"></i> Copy
                            </button>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="no-coupons">
                <i class="fa-solid fa-ticket"></i>
                <p>No coupons available at the moment.</p>
            </div>
        <% } %>
    </div>
    

<div class="container">
                    <nav aria-label="page navigation">
                        <ul class="pagination justify-cotent-center mb-20"style="margin-right:20px";>
                            <%for(let i=1;i<=totalPages;i++){%>
                                <li class="page-item <%=(i===currentPage)? 'active':''%>">
                                 <a class="page-link" href="?page=<%= i %>"><%= i %></a>
                                </li>
                                <%}%>
                        </ul>
                    </nav>
                </div>
   </section>
        </div>
        
    </main>

    <footer class="footer">
        <div class="footer-columns">
            <div class="col">
                <h4>About Us:</h4>
                <p>Our Story</p><p>Privacy Policy</p><p>Terms</p><p>FAQ</p>
            </div>
            <div class="col">
                <h4>Support:</h4>
                <p>Shipping Policy</p><p>Returns</p><p>Order Tracking</p><p>Help</p>
            </div>
            <div class="col">
                <h4>My Account:</h4>
                <p>Profile</p><p>My Orders</p><p>Wishlist</p><p>Refer & Earn</p>
            </div>
            <div class="col">
                <h4>Contact:</h4>
                <p>Email: visionvogue@gmail.com</p>
                <p>Phone: 8923457190</p>
            </div>
        </div>
        <p class="copyright">© 2026 Eyewear Store. All rights reserved.</p>
    </footer>
 <script>
    window.addEventListener("pageshow", function (event) {
        var historyTraversal = event.persisted || 
                               (typeof window.performance != "undefined" && 
                                window.performance.navigation.type === 2);
        if (historyTraversal) {
            window.location.reload();
        }
    });
    window.history.pushState(null, null, window.location.href);
    window.onpopstate = function () {
        window.history.go(1);
        
    };
function copyCode(id) {
    const codeText = document.getElementById('code-' + id).innerText;
    navigator.clipboard.writeText(codeText).then(() => {
        // ഭംഗിയുള്ള ടോസ്റ്റ് മെസ്സേജ്
        const Toast = Swal.mixin({
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 2000,
            timerProgressBar: true
        });

        Toast.fire({
            icon: 'success',
            title: 'Coupon code copied: ' + codeText
        });
    });
}
</script>
</body>
</html>