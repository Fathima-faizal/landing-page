<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VisionVogue - ProductDetails</title>
    <link rel="stylesheet" href="/css/productDetails.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
      <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
    
    <header>
        <nav class="navbar">
            <ul class="nav-links">
                <li><a href="/home">Home</a></li>
                <li><a href="/shop">shop</a></li>
                <li><a href="#">About</a></li>
                <li><a href="#">Contact us</a></li>
            </ul>
            <div class="logo">VisionVogue</div>
            <div class="nav-icons">
               <a href="/wishlist" ><i class="fa-regular fa-heart"></i></a>
              <a href="/cart" class="cart-icon-container"> <i class="fa-solid fa-cart-shopping"></i>
            <% if (locals.cartCount > 0) { %>
            <span class="cart-badge"><%= cartCount %></span>
        <% } %></a>
              <a href="/profile" > <i class="fa-regular fa-user"></i></a>
            </div>
        </nav>
    </header>
    <main class="product-page-wrapper">
    <div class="product-container">
        <div class="gallery-section">
            <div class="main-display-card">
                <div class="image-zoom-container" id="zoomContainer">
                    <img id="mainProductImage" src="/uploads/<%=product.productimage[0]%>" alt="<%= product.productName %>">
                </div>
                <% if (product.quantity <= 5 && product.quantity > 0) { %>
                    <span class="stock-badge low-stock">Only <%= product.quantity %> left!</span>
                <% } %>
            </div>
            
            <div class="thumbnail-grid">
                <% product.productimage.forEach((img, index) => { %>
                    <div class="thumb-card <%= index === 0 ? 'active-thumb' : '' %>" onclick="changeImage('/uploads/<%= img %>', this)">
                        <img src="/uploads/<%= img %>" alt="Thumbnail">
                    </div>
                <% }) %>
            </div>
        </div>

        <div class="info-section-glass">
            <nav class="breadcrumb">
                <a href="/home">Home</a> / <a href="/shop">Shop</a> / <span><%= product.category.name %></span>
            </nav>

            <div class="product-header">
                <h1 class="product-title"><%= product.productName %></h1>
                <div class="brand-tag"><%= product.brand %></div>
            </div>

            <div class="price-section">
                <div class="price-wrapper">
                    <% if (product.salesPrice < product.regularPrice) { %>
                        <span class="sale-price">₹<%= product.salesPrice %></span>
                        <span class="mrp-price">₹<%= product.regularPrice %></span>
                        <% let discount = Math.round(((product.regularPrice - product.salesPrice) / product.regularPrice) * 100); %>
                        <span class="discount-percent"><%= discount %>% OFF</span>
                    <% } else { %>
                        <span class="sale-price">₹<%= product.regularPrice %></span>
                    <% } %>
                </div>
                <p class="tax-note">Price inclusive of all taxes</p>
            </div>

            <div class="divider"></div>

            <div class="description-section">
                <h3>Overview</h3>
                <p><%= product.description %></p>
            </div>

            <div class="purchase-zone">
                <div class="qty-container">
                    <span class="label">Quantity</span>
                    <div class="qty-picker">
                        <button type="button" onclick="updateQty(-1)">-</button>
                        <input type="number" id="quantity" value="1" readonly>
                        <button type="button" onclick="updateQty(1)">+</button>
                    </div>
                </div>
                <div class="button-actions">
    <% if (!isOutOfStock) { %>
        <button class="btn-primary add-to-cart" onclick="addToCart('<%=product._id%>')">
            <i class="fa-solid fa-cart-plus"></i> Add to Cart
        </button>
    <% } else { %>
        <button class="btn-out-of-stock" disabled style="background-color: #ff4d4d; color: white; cursor: not-allowed;">
            <% if (product.isBlocked) { %>
                Currently Unavailable
            <% } else { %>
                Out of Stock
            <% } %>
        </button>
    <% } %>
</div>
            </div>

            <div class="service-features">
                <div class="feature-item">
                    <i class="fa-solid fa-truck-moving"></i>
                    <span>Free Shipping</span>
                </div>
                <div class="feature-item">
                    <i class="fa-solid fa-arrow-rotate-left"></i>
                    <span>7 Days Return</span>
                </div>
                <div class="feature-item">
                    <i class="fa-solid fa-certificate"></i>
                    <span>100% Authentic</span>
                </div>
            </div>
        </div>
    </div>
<section class="related-wrapper">
    <div class="section-header">
        <h2>You May Also Like</h2>
        <div class="underline"></div>
    </div>
    
    <div class="related-grid">
        <% if (relatedProducts && relatedProducts.length > 0) { %>
            <% relatedProducts.slice(0, 3).forEach(item => { %> <div class="product-card-mini">
                    <a href="/productDetails?id=<%= item._id %>">
                        <div class="img-wrapper">
                            <img src="/uploads/<%= item.productimage[0] %>" alt="<%= item.productName %>">
                        </div>
                        <div class="mini-info">
                            <h4 class="mini-name"><%= item.productName %></h4>
                            <div class="mini-price-row">
                                <span class="mini-price">₹<%= item.salesPrice %></span>
                                <% if (item.regularPrice > item.salesPrice) { %>
                                    <span class="mini-old-price">₹<%= item.regularPrice %></span>
                                <% } %>
                            </div>
                        </div>
                    </a>
                </div>
            <% }) %>
        <% } else { %>
            <p class="no-results">No similar items found.</p>
        <% } %>
    </div>
</section>
</main>
     <footer>
        <div class="footer-content">
            <div class="footer-column">
                <h4>About Us:</h4>
                <a href="#">Our Story</a>
                <a href="#">Privacy Policy</a>
                <a href="#">Terms</a>
                <a href="#">FAQ</a>
            </div>
            <div class="footer-column">
                <h4>Support:</h4>
                <a href="#">Shipping Policy</a>
                <a href="#">Returns</a>
                <a href="#">Order Tracking</a>
                <a href="#">Help</a>
            </div>
            <div class="footer-column">
                <h4>My Account:</h4>
                <a href="#">Profile</a>
                <a href="#">My Orders</a>
                <a href="#">Wishlist</a>
                <a href="#">Refer & Earn</a>
            </div>
            <div class="footer-column">
                <h4>Contact:</h4>
                <p>Email: visionvogue@gmail.com</p>
                <p>Phone: 8923457190</p>
            </div>
        </div>
        <p class="copyright">© 2026 Eyewear Store. All rights reserved.</p>
    </footer>
    
   <script>
function changeImage(imagePath, element) {
    const mainImg = document.getElementById('mainProductImage');
    mainImg.src = imagePath;
    document.querySelectorAll('.thumb-card').forEach(card => card.classList.remove('active-thumb'));
    element.classList.add('active-thumb');
}

const container = document.getElementById('zoomContainer');
const img = document.getElementById('mainProductImage');

container.addEventListener('mousemove', (e) => {
    const rect = container.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;

    img.style.transformOrigin = `${x}px ${y}px`;
    img.style.transform = "scale(2.5)";
});

container.addEventListener('mouseleave', () => {
    img.style.transformOrigin = "center";
    img.style.transform = "scale(1)";
});

function updateQty(val) {
    const qtyInput = document.getElementById('quantity');
    let currentQty = parseInt(qtyInput.value);
    let maxQty = 3; 

    let newQty = currentQty + val;

    if (newQty >= 1 && newQty <= maxQty) {
        qtyInput.value = newQty;
    } else if (newQty > maxQty) {
        Swal.fire({
            icon: 'warning',
            title: 'Limit Exceeded',
            text: 'You can only add a maximum of 3 units.',
            timer: 1500,
            showConfirmButton: false
        });
    }
}
function addToCart(productId) {
    const quantity = parseInt(document.getElementById('quantity').value);

    $.ajax({
        url: '/cart',
        method: 'POST',
        data: { 
            productId: productId,
            quantity: quantity 
        },
        success: (response) => {
            if (response.status) {
                const badge = document.querySelector('.cart-badge');
                if (badge) {
                    badge.innerHTML = response.cartLength;
                } else {
                    const container = document.querySelector('.cart-icon-container');
                    const newBadge = document.createElement('span');
                    newBadge.className = 'cart-badge';
                    newBadge.innerHTML = response.cartLength;
                    container.appendChild(newBadge);
                }
                Swal.fire({
                    icon: 'success',
                    title: 'Added to cart',
                    text: 'The product has been added to your Cart',
                    timer: 2000
                });
            } else {
                Swal.fire({
                    icon: 'info',
                    title: 'Already in Cart',
                    text: response.message
                });
            }
        },
        error: (error) => {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'Something went wrong!'
            });
        }
    });
}
</script>
</body>
</html>