<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VisionVogue - Profile</title>
    <link rel="stylesheet" href="css/addAddress.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>

    <header class="navbar">
        <nav class="nav-links">
            <a href="#">Home</a>
            <a href="#">shop</a>
            <a href="#">About</a>
            <a href="#">Contact us</a>
        </nav>
        <div class="logo">VisionVogue</div>
        <div class="nav-icons">
              <a href="/wishlist" class="wishlist-icon-container" style="position: relative; display: inline-block;">
        <i class="fa-regular fa-heart"></i>
        <% if (locals.wishlistCount > 0) { %>
            <span class="wishlist-badge"><%= wishlistCount %></span>
        <% } %>
    </a>
               <a href="/cart" class="cart-icon-container"><i class="fa-solid fa-cart-shopping"></i>
                <% if (locals.cartCount > 0) { %>
            <span class="cart-badge"><%= cartCount %></span>
        <% } %>
            </a>
              <a href="" > <i class="fa-regular fa-user"></i></a>
    </header>

    <main class="profile-container">
        <p>Address -> New Address</p>
        
        <div class="content-wrapper">
            <aside class="sidebar">
                <h3>My Account</h3>
                <ul>
                   <a href="/profile"><li>Profile</li></a>
                   <a href="/address"> <li class="active">Address</li> </a>
                   <a href="/order"><li>Order</li> </a>
                   <a href="/wallet"><li>Wallet</li> </a>
                   <a href="/Coupon"> <li>Coupon</li> </a>
                   <a href="/refer" ><li>Refer & Earn</li> </a>
                   <a href="/password"><li>Change Password</li> </a>
                   <a href="/logout"><li>Log out</li> </a>
                </ul>
            </aside>
           <main class="profile-container">
    <div class="form-wrapper-centered">

        <div class="form-card-premium">
            <div class="form-header">
                <div class="icon-circle">
                    <i class="fa-solid fa-location-dot"></i>
                </div>
                <h2>New Shipping Address</h2>
                <p>Add a new location for your deliveries</p>
            </div>

            <form method="post" action="/addAddress" id="addressForm">
                <div class="form-grid">
                    <div class="form-group full-width">
                        <label>Address Type</label>
                        <input type="text" id="addressType" name="addressType" placeholder="Address Type" >
                    </div>

                    <div class="form-group">
                        <label>House Name/No.</label>
                        <input type="text" id="houseName" name="houseName" placeholder="House Name" >
                    </div>

                    <div class="form-group">
                        <label>Street</label>
                        <input type="text" id="street" name="street" placeholder="Street">
                    </div>

                    <div class="form-group full-width">
                        <label>Landmark</label>
                        <input type="text" id="landmark" name="landmark" placeholder="Landmark">
                    </div>

                    <div class="form-group">
                        <label>City</label>
                        <input type="text" id="city" name="city" placeholder="City" >
                    </div>

                    <div class="form-group">
                        <label>Zip Code</label>
                        <input type="text" id="zipCode" name="zipCode" placeholder="Zip Code" >
                    </div>

                    <div class="form-group">
                        <label>Country</label>
                        <input type="text" id="country" name="country" placeholder="Country" >
                    </div>

                    <div class="form-group">
                        <label>Phone Number</label>
                        <input type="text" id="phoneNumber" name="phoneNumber" placeholder="Phone Number" >
                    </div>
                </div>

                <div id="formError" class="error-message"></div>

                <div class="form-actions">
                    <button type="submit" class="btn-save">
                        Save Address <i class="fa-solid fa-check"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
</main>
        </div>
    </main>

    <footer class="footer">
        <div class="footer-columns">
            <div class="col">
                <h4>About Us:</h4>
                <p>Our Story</p><p>Privacy Policy</p><p>Terms</p><p>FAQ</p>
            </div>
            <div class="col">
                <h4>Support:</h4>
                <p>Shipping Policy</p><p>Returns</p><p>Order Tracking</p><p>Help</p>
            </div>
            <div class="col">
                <h4>My Account:</h4>
                <p>Profile</p><p>My Orders</p><p>Wishlist</p><p>Refer & Earn</p>
            </div>
            <div class="col">
                <h4>Contact:</h4>
                <p>Email: visionvogue@gmail.com</p>
                <p>Phone: 8923457190</p>
            </div>
        </div>
        <p class="copyright">© 2026 Eyewear Store. All rights reserved.</p>
    </footer>
<script>
document.getElementById('addressForm').addEventListener('submit', function(e) {
    const addressType = document.getElementById('addressType').value.trim();
    const houseName = document.getElementById('houseName').value.trim();
    const street = document.getElementById('street').value.trim();
    const landmark = document.getElementById('landmark').value.trim();
    const city = document.getElementById('city').value.trim();
    const zipCode = document.getElementById('zipCode').value.trim();
    const country = document.getElementById('country').value.trim();
    const phoneNumber = document.getElementById('phoneNumber').value.trim();
    const formError = document.getElementById('formError');

    const phoneRegex = /^[6-9]\d{9}$/; 
    const zipRegex = /^\d{6}$/;       
    
    let errorMessage = "";

    // 1. Check for empty fields first
    if (!addressType || !houseName || !street || !landmark || !city || !zipCode || !country || !phoneNumber) {
        errorMessage = "All fields are required. Please fill in every detail.";
    } 
    // 2. Then check Zip Code
    else if (!zipRegex.test(zipCode)) {
        errorMessage = "Please enter a valid 6-digit Zip Code.";
    }
    // 3. Then check Phone Number
    else if (!phoneRegex.test(phoneNumber)) {
        errorMessage = "Please enter a valid 10-digit phone number starting with 6-9.";
    }

    if (errorMessage) {
        e.preventDefault(); 
        formError.innerText = errorMessage;
        formError.style.display = "block";
        formError.style.color = "#ff4d4d";
        window.scrollTo({ top: formError.offsetTop - 100, behavior: 'smooth' });
    } else {
        formError.style.display = "none";
    }
});
</script>


</body>
</html>