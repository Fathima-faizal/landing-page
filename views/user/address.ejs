<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VisionVogue - Profile</title>
    <link rel="stylesheet" href="css/address.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>

    <header class="navbar">
        <nav class="nav-links">
            <a href="home">Home</a>
            <a href="#">shop</a>
            <a href="#">About</a>
            <a href="#">Contact us</a>
        </nav>
        <div class="logo">VisionVogue</div>
        <div class="nav-icons">
             <a href="/wishlist" class="wishlist-icon-container" style="position: relative; display: inline-block;">
        <i class="fa-regular fa-heart"></i>
        <% if (locals.wishlistCount > 0) { %>
            <span class="wishlist-badge"><%= wishlistCount %></span>
        <% } %>
    </a>
               <a href="/cart" class="cart-icon-container"><i class="fa-solid fa-cart-shopping"></i>
                <% if (locals.cartCount > 0) { %>
            <span class="cart-badge"><%= cartCount %></span>
        <% } %>
            </a>
              <a href="/profile" > <i class="fa-regular fa-user"></i></a>
    </header>
   <main class="profile-container">
        <h1>Address</h1>
        
        <div class="content-wrapper">
            <aside class="sidebar">
                <h3>My Account</h3>
                <ul>
                   <a href="/profile"><li >Profile</li></a>
                   <a href="/address"> <li class="active">Address</li> </a>
                   <a href="/order"><li>Order</li> </a>
                   <a href="/wallet"><li>Wallet</li> </a>
                   <a href="/Coupon"> <li>Coupon</li> </a>
                   <a href="/refer" ><li>Refer & Earn</li> </a>
                   <a href="/password"><li>Change Password</li> </a>
                   <a href="/logout"><li>Log out</li> </a>
                </ul>
            </aside>
           <div class="address-grid">
            <div class="add-address-card-new">
                <div class="add-icon"><i class="fa-solid fa-plus"></i></div>
                <h4>Add New Address</h4>
                <p>Click here to add a new shipping location</p>
                <a href="/addAddress" class="btn-add-minimal">Add Address</a>
            </div>

            <% if (userAddress && userAddress.address.length > 0) { %>
                <% userAddress.address.forEach((address)=>{ %>
                    <div class="address-card-premium <%= address.isDefault ? 'default-border' : '' %>">
                        <div class="card-header">
                            <span class="type-tag"><%= address.addressType %></span>
                            <% if (address.isDefault) { %>
                                <span class="default-badge"><i class="fa-solid fa-circle-check"></i> Default</span>
                            <% } %>
                        </div>
                        
                        <div class="address-body">
                            <h4 class="user-name"><%= address.houseName %></h4>
                            <p><i class="fa-solid fa-map-pin"></i> <%= address.street %>, <%= address.landmark %></p>
                            <p><%= address.city %>, <%= address.country %> - <strong><%= address.zipCode %></strong></p>
                            <p class="phone-row"><i class="fa-solid fa-phone"></i> <%= address.phoneNumber %></p>
                        </div>

                        <div class="card-actions">
                            <a href="/editAddress?id=<%=address._id%>" class="action-link edit"><i class="fa-regular fa-pen-to-square"></i> Edit</a>
                           <a href="#" class="action-link delete" onclick="confirmDelete(event, '<%= address._id %>')"><i class="fa-regular fa-trash-can"></i> Delete</a>
                            <% if(!address.isDefault) { %>
                                <a href="/defaultAddress?id=<%=address._id%>" class="set-default">Set as Default</a>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </div>
        </div>
        <div class="container">
                    <nav aria-label="page navigation">
                        <ul class="pagination justify-cotent-center mb-20"style="margin-right:20px";>
                            <%for(let i=1;i<=totalPages;i++){%>
                                <li class="page-item <%=(i===currentPage)? 'active':''%>">
                                 <a class="page-link" href="?page=<%= i %>"><%= i %></a>
                                </li>
                                <%}%>
                        </ul>
                    </nav>
                </div>
    </main>


    <footer class="footer">
        <div class="footer-columns">
            <div class="col">
                <h4>About Us:</h4>
                <p>Our Story</p><p>Privacy Policy</p><p>Terms</p><p>FAQ</p>
            </div>
            <div class="col">
                <h4>Support:</h4>
                <p>Shipping Policy</p><p>Returns</p><p>Order Tracking</p><p>Help</p>
            </div>
            <div class="col">
                <h4>My Account:</h4>
                <p>Profile</p><p>My Orders</p><p>Wishlist</p><p>Refer & Earn</p>
            </div>
            <div class="col">
                <h4>Contact:</h4>
                <p>Email: visionvogue@gmail.com</p>
                <p>Phone: 8923457190</p>
            </div>
        </div>
        <p class="copyright">© 2026 Eyewear Store. All rights reserved.</p>
    </footer>
  <script>
    function confirmDelete(event, addressId) {
    // Prevent the page from following the link or reloading immediately
    event.preventDefault();

    Swal.fire({
        title: "Are you sure?",
        text: "This address will be permanently removed from your profile.",
        icon: "warning",
        showCancelButton: true,
        confirmButtonColor: "#ff4d4d", // Red color to match your delete theme
        cancelButtonColor: "#6c757d",
        confirmButtonText: "Yes, delete it!",
    }).then((result) => {
        if (result.isConfirmed) {
            // If confirmed, redirect to the delete route
            window.location.href = `/deleteAddress?id=${addressId}`;
        }
    });
}
    window.addEventListener( "pageshow", function ( event ) {
        var historyTraversal = event.persisted || 
                               ( typeof window.performance != "undefined" && 
                                 window.performance.navigation.type === 2 );
        if ( historyTraversal ) {
            window.location.reload();
        }
    });
    window.history.pushState(null, null, window.location.href);
    window.onpopstate = function () {
        window.history.go(1);
    };
  </script>
</body>
</html>