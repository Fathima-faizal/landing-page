<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VisionVogue - Profile</title>
    <link rel="stylesheet" href="css/profile.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>

    <header class="navbar">
        <nav class="nav-links">
            <a href="/home">Home</a>
            <a href="/shop">shop</a>
            <a href="#">About</a>
            <a href="#">Contact us</a>
        </nav>
        <div class="logo">VisionVogue</div>
        <div class="nav-icons">
            <a href="/wishlist" class="wishlist-icon-container" style="position: relative; display: inline-block;">
        <i class="fa-regular fa-heart"></i>
        <% if (locals.wishlistCount > 0) { %>
            <span class="wishlist-badge"><%= wishlistCount %></span>
        <% } %>
    </a>
               <a href="/cart" class="cart-icon-container"> <i class="fa-solid fa-cart-shopping"></i>
            <% if (locals.cartCount > 0) { %>
            <span class="cart-badge"><%= cartCount %></span>
        <% } %></a>
              <a href="/profile" > <i class="fa-regular fa-user"></i></a>
    </header>

    <main class="profile-container">
        <h1>Profile</h1>
        
        <div class="content-wrapper">
            <aside class="sidebar">
                <h3>My Account</h3>
                <ul>
                   <a href="/profile"><li class="active">Profile</li></a>
                   <a href="/address"> <li>Address</li> </a>
                   <a href="/order"><li>Order</li> </a>
                   <a href="/wallet"><li>Wallet</li> </a>
                   <a href="/Coupon"> <li>Coupon</li> </a>
                   <a href="/refer" ><li>Refer & Earn</li> </a>
                   <a href="/password"><li>Change Password</li> </a>
                   <a href="/logout"><li>Log out</li> </a>
                </ul>
            </aside>

            <section class="profile-card">
    <div class="profile-header">
        <div class="avatar-circle">
            <div class="avatar-circle">
    <% if (user.profileImage && user.profileImage !== 'default-avatar.png') { %>
        <img src="/uploads/profileImage/<%= user.profileImage %>" alt="Profile" 
             style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
    <% } else { %>
        <i class="fa-solid fa-user"></i>
    <% } %>
</div>
        </div>
        <h2>Personal Information</h2>
    </div>
    
    <div class="info-group">
        <label>Full Name</label>
        <div class="info-value"><%=user.name%></div>
    </div>

    <div class="info-group">
        <label>Email Address</label>
        <div class="info-value"><%=user.email%></div>
    </div>
      <div class="profile-actions">
        <a href="/editProfile" class="edit-btns">Edit Profile</a>
        <a href="/changeEmail" class="edit-btn">Change Email</a>
    </div>
</section>
        </div>
    </main>

    <footer class="footer">
        <div class="footer-columns">
            <div class="col">
                <h4>About Us:</h4>
                <p>Our Story</p><p>Privacy Policy</p><p>Terms</p><p>FAQ</p>
            </div>
            <div class="col">
                <h4>Support:</h4>
                <p>Shipping Policy</p><p>Returns</p><p>Order Tracking</p><p>Help</p>
            </div>
            <div class="col">
                <h4>My Account:</h4>
                <p>Profile</p><p>My Orders</p><p>Wishlist</p><p>Refer & Earn</p>
            </div>
            <div class="col">
                <h4>Contact:</h4>
                <p>Email: visionvogue@gmail.com</p>
                <p>Phone: 8923457190</p>
            </div>
        </div>
        <p class="copyright">© 2026 Eyewear Store. All rights reserved.</p>
    </footer>
 <script>
    window.addEventListener("pageshow", function (event) {
        var historyTraversal = event.persisted || 
                               (typeof window.performance != "undefined" && 
                                window.performance.navigation.type === 2);
        if (historyTraversal) {
            window.location.reload();
        }
    });
    window.history.pushState(null, null, window.location.href);
    window.onpopstate = function () {
        window.history.go(1);
    };
</script>
</body>
</html>