<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Professional Admin Dashboard</title>
    <link rel="stylesheet" href="/css/offer.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>

    <div class="dashboard-container">
        <aside class="sidebar">
            <div class="nav-item ">
                <a href="/admin/dashboard">
                <i class="fas fa-th-large"></i> <span>Dashboard</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/product">
                <i class="fas fa-box"></i> <span>Product Management</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/orderManagement">
                <i class="fas fa-shopping-cart"></i> <span>Order Management</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/customer">
                <i class="fas fa-user"></i> <span>User Management</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/category">
                <i class="fas fa-layer-group"></i> <span>Category Management</span>
                </a>
            </div>
           <div class="nav-item">
                <a href="/admin/banner">
                <i class="fas fa-image"></i> <span>Banner Management</span>
                </a>
            </div>
             <div class="nav-item">
                <a href="/admin/inventory">
                <i class="fa-solid fa-clipboard-list"></i> <span>Invetry Management</span>
                </a>
            </div>
            <hr class="nav-divider">

            <div class="nav-item">
                <a href="/admin/couponManagement">
              <i class="fas fa-ticket-alt"></i>  <span>Coupon</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/brand">
              <i class="fa-solid fa-tags"></i> <span>Brand</span>
                </a>
            </div>
             <div class="nav-item">
                <a href="/admin/Reviews">
                <i class="fas fa-comment-alt"></i> <span>Review</span>
                </a>
            </div>
            <div class="nav-item active">
                <a href="/admin/offer">
                 <i class="fas fa-tag"></i> <span>Offers</span>
                </a>
            </div>
        </aside>

        <main class="main-content">
            <header class="top-header">
                <h2>Offer Management</h2>
                <a href="/admin/logout">
                <button class="logout-top">Log out</button>
                </a>
            </header>
            <section class="content-body">
                <div class="toolbar">
                    <form action="/admin/offer" method="get">
                    <div class="search-box">
                        <input type="text" name="search" placeholder="Search">
                        <button class="btn-clear">Clear</button>
                        </form>
                       
                    </div>
                    <a href="/admin/addOffer"><button class="btn-add">Add new Offer</button></a>
                </div>
                <table class="inventory-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Discount</th>
                <th>Type</th>
                <th>Expiry</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <% offers.forEach(offer => { %>
                <tr>
                    <td><%= offer.offerName %></td>
                    <td><%= offer.discountPercentage %>%</td>
                    <td><%= offer.offerType %></td>
                    <td><%= offer.expiryDate.toLocaleDateString('en-us') %></td>
                    <td class="actions">
                     <% if(offer.isActive === false) { %>
                <a href="/admin/activeOffer?id=<%=offer._id%>">
                    <button class="btn-block">UnActive</button>
                </a>
            <% } else { %>
                <a href="/admin/unactiveOffer?id=<%=offer._id%>">
                    <button class="btn-unblock">Active</button>
                </a>
            <% } %>
            <a href="/admin/editOffer/<%=offer._id%>">
    <i class="fa-regular fa-pen-to-square" style="color: black; margin-top: 5px;"></i>
</a>
             <a href="javascript:void(0)" onclick="confirmDeleteOffer('<%=offer._id%>', '<%=offer.offerName%>')">
    <i class="fa-regular fa-trash-can" style="color:red;margin-top: 5px;"></i>
</a>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
        
                <div class="container">
                    <nav aria-label="page navigation">
                        <ul class="pagination justify-cotent-center mb-20"style="margin-right:20px";>
                            <%for(let i=1;i<=totalPages;i++){%>
                                <li class="page-item <%=(i===currentPage)? 'active':''%>">
                                 <a class="page-link" href="?page=<%= i %>&search=<%= search %>"><%= i %></a>
                                </li>
                                <%}%>
                        </ul>
                    </nav>
                </div>
            </section>
        </main>
    </div>
   <script>
    window.addEventListener("pageshow", function (event) {
        var historyTraversal = event.persisted || 
                               (typeof window.performance != "undefined" && 
                                window.performance.navigation.type === 2);
        if (historyTraversal) {
            window.location.reload();
        }
    });
    window.history.pushState(null, null, window.location.href);
    window.onpopstate = function () {
        window.history.go(1);
    };
    function confirmDeleteOffer(id, name) {
    Swal.fire({
        title: 'Remove Offer?',
        text: `Are you sure you want to delete the offer "${name}"? This will revert the prices of associated products.`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#3085d6',
        confirmButtonText: 'Yes, Delete Offer!'
    }).then((result) => {
        if (result.isConfirmed) {
            window.location.href = `/admin/deleteOffer?id=${id}`;
        }
    });
}
</script>
</body>
</html>