<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Professional Admin Dashboard</title>
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.25/jspdf.plugin.autotable.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
</head>
<body>

<div class="dashboard-container">
    <aside class="sidebar">
        <div class="nav-item active">
                <a href="/admin/dashboard">
                <i class="fas fa-th-large"></i> <span>Dashboard</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/product">
                <i class="fas fa-box"></i> <span>Product Management</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/orderManagement">
                <i class="fas fa-shopping-cart"></i> <span>Order Management</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/customer">
                <i class="fas fa-user"></i> <span>User Management</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/category">
                <i class="fas fa-layer-group"></i> <span>Category Management</span>
                </a>
            </div> 
            <div class="nav-item">
                <a href="/admin/banner">
                <i class="fas fa-image"></i> <span>Banner Management</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/inventory">
                <i class="fa-solid fa-clipboard-list"></i> <span>Invetry Management</span>
                </a>
            </div>
            <hr class="nav-divider">

            <div class="nav-item">
                <a href="/admin/couponManagement">
                <i class="fas fa-ticket-alt"></i> <span>Coupon</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/brand">
               <i class="fa-solid fa-tags"></i><span>Brand</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/Reviews">
                <i class="fas fa-comment-alt"></i> <span>Review</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/offer">
               <i class="fas fa-tag"></i> <span>Offers</span>
                </a>
            </div>
        </aside>

    <main class="main-content">
        <header class="top-header">
            <h2>Admin Dashboard</h2>
            <a href="/admin/logout"><button class="logout-top">Log out</button></a>
        </header>

        <div class="content-body">
            
            <div class="stats-grid">
                <div class="stat-card"><i class="fas fa-users"></i><div><p>Users</p><h3><%= userCount %></h3></div></div>
                <div class="stat-card"><i class="fas fa-shopping-cart"></i><div><p>Orders</p><h3><%= orderCount %></h3></div></div>
                <div class="stat-card"><i class="fas fa-wallet"></i><div><p>Revenue</p><h3>₹<%= revenue %></h3></div></div>
            </div>

            <div style="margin: 20px 0; display: flex; justify-content: flex-end;">
                <button id="toggleBtn" onclick="toggleDashboard()" class="filter-btn" style="min-width: 150px; background-color: #3498db; color: white; border: none; padding: 10px; border-radius: 5px; cursor: pointer;">
                    Show Sales Report
                </button>
            </div>

            <div id="revenueSection" class="charts-container" style="background: white; padding: 20px; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                <h3>Revenue Analytics (Monthly)</h3>
                <div style="height: 300px;">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>

            <div id="salesSection" class="report-section" style="margin-top: 20px; display: none;">
                <div class="report-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h3>Sales Report</h3>
                    <div class="filter-group">
                        <select id="filterType" onchange="toggleDateInputs()">
                            <option value="custom">Custom Range</option>
                            <option value="daily">Daily</option>
                            <option value="weekly">Weekly</option>
                            <option value="yearly">Yearly</option>
                        </select>
                        <input type="date" id="startDate">
                        <input type="date" id="endDate">
                        <button class="filter-btn" onclick="applyFilter()"><i class="fas fa-filter"></i> Filter</button>
                    </div>
                </div>

                <table class="report-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Order ID</th>
                            <th>Price</th>
                            <th>Discount</th>
                            <th>Final Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% salesReport.forEach(order => { %>
                        <tr>
                            <td><%= order.createdOn.toLocaleDateString() %></td>
                            <td>#<%= order._id.toString() %></td>
                            <td>₹<%= order.totalPrice %></td>
                            <td>₹<%= order.discount %></td>
                            <td>₹<%= order.finalAmount %></td>
                            <% 
    let statusClass = 'status-black';
    if(order.status === 'cancelled') statusClass = 'status-red';
    else if(order.status === 'delivered') statusClass = 'status-green';
    else if(order.status === 'pending') statusClass = 'status-yellow';
%>

<td class="<%= statusClass %>">
    <%= order.status.toUpperCase() %>
</td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>

                <div style="margin-top: 20px; display: flex; justify-content: flex-end; gap: 10px;">
                    <button class="download-btn" onclick="downloadPDF()" style="background: #e74c3c; color: white; border: none; padding: 10px 20px; border-radius: 5px; cursor: pointer;">
                        <i class="fas fa-file-pdf"></i> PDF
                    </button>
                    <button class="download-btn" onclick="downloadExcel()" style="background: #27ae60; color: white; border: none; padding: 10px 20px; border-radius: 5px; cursor: pointer;">
                        <i class="fas fa-file-excel"></i> Excel (CSV)
                    </button>
                </div>
            </div>
        </div>
    </main>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
    const today = new Date();
    const dd = String(today.getDate()).padStart(2, '0');
    const mm = String(today.getMonth() + 1).padStart(2, '0'); 
    const yyyy = today.getFullYear();
    const todayFormatted = yyyy + '-' + mm + '-' + dd;
    const startInput = document.getElementById('startDate');
    const endInput = document.getElementById('endDate');
    startInput.setAttribute('max', todayFormatted);
    endInput.setAttribute('max', todayFormatted)
    startInput.addEventListener('change', function() {
        endInput.setAttribute('min', startInput.value);
    });
});
    function toggleDashboard() {
        const revenue = document.getElementById('revenueSection');
        const sales = document.getElementById('salesSection');
        const btn = document.getElementById('toggleBtn');

        if (revenue.style.display === 'none') {
            revenue.style.display = 'block';
            sales.style.display = 'none';
            btn.innerText = 'Show Sales Report';
            btn.style.backgroundColor = '#3498db';
        } else {
            revenue.style.display = 'none';
            sales.style.display = 'block';
            btn.innerText = 'Show Revenue Analytics';
            btn.style.backgroundColor = '#2c3e50';
        }
    }

    const rawData = JSON.parse('<%- chartData %>'); 
    const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
    const labels = rawData.map(item => months[item._id - 1]);
    const values = rawData.map(item => item.revenue);
    const ctx = document.getElementById('revenueChart').getContext('2d');
    
    const gradient = ctx.createLinearGradient(0, 0, 0, 400);
    gradient.addColorStop(0, 'rgba(52, 152, 219, 0.2)'); 
    gradient.addColorStop(1, 'rgba(52, 152, 219, 0)');  

    new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                label: 'Growth Analytics',
                data: values,
                borderColor: 'rgba(52, 152, 219, 0.8)', 
                borderWidth: 4,                        
                backgroundColor: gradient, 
                fill: true,
                tension: 0, 
                pointRadius: 6,                        
                pointBackgroundColor: '#3498db',
                showLine: true                        
            }]
        },
        options: { 
            responsive: true, 
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, grid: { color: 'rgba(0, 0, 0, 0.05)' } },
                x: { grid: { display: false } }
            }
        }
    });
    async function applyFilter() {
        const startDate = document.getElementById('startDate').value;
    const endDate = document.getElementById('endDate').value;
    const filterType = document.getElementById('filterType').value;
        if (filterType === 'custom') {
        if (!startDate || !endDate) return alert("Please select both dates");

        const today = new Date();
        today.setHours(23, 59, 59, 999);
       if (new Date(startDate) > today || new Date(endDate) > today) {
            return alert("Future dates are not allowed");
        }

        if (new Date(startDate) > new Date(endDate)) {
            return alert("Start date cannot be after end date");
        }
    }
        const response = await fetch(`/admin/salesReport?startDate=${startDate}&endDate=${endDate}&filterType=${filterType}`);
        const data = await response.json();
        updateTable(data);
    }

    function updateTable(data) {
        const tbody = document.querySelector('.report-table tbody');
        tbody.innerHTML = data.map(order => `
            <tr>
                <td>${new Date(order.createdOn).toLocaleDateString()}</td>
                <td>#${order._id.toString()}</td>
                <td>₹${order.totalPrice}</td>
                <td>₹${order.discount}</td>
                <td>₹${order.finalAmount}</td>
                <span style="color: ${order.status === 'cancelled' ? 'red' : order.status === 'delivered' ? 'green' : 'orange'}">
                    ${order.status.toUpperCase()}
                </span>
            </tr>
        `).join('');
    }


    function downloadExcel() {
        const table = document.querySelector(".report-table");
        const ws = XLSX.utils.table_to_sheet(table);
         const wscols = [
        {wch: 15},
        {wch: 30}, 
        {wch: 12}, 
        {wch: 12}, 
        {wch: 15} 
        ];
        ws['!cols'] = wscols;
        const wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, "Sales Report");
        XLSX.writeFile(wb, "Sales_Report.xlsx");
    }

    function updateTable(data) {
    const tbody = document.querySelector('.report-table tbody');
    tbody.innerHTML = data.map(order => `
        <tr>
            <td>${new Date(order.createdOn).toLocaleDateString()}</td>
            <td>#${order._id.toString()}</td>
            <td>₹${order.totalPrice}</td>
            <td>₹${order.discount}</td>
            <td>₹${order.finalAmount}</td>
            <td>
                <span style="color: ${order.status === 'cancelled' ? 'red' : order.status === 'delivered' ? 'green' : 'orange'}">
                    ${order.status.toUpperCase()}
                </span>
            </td>
        </tr>
    `).join('');
}

function downloadPDF() {
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF();
    doc.setFontSize(18);
    doc.text("VisionVogue Sales Report", 14, 15);
    doc.setFontSize(10);
    doc.text(`Generated on: ${new Date().toLocaleString()}`, 14, 22);
    doc.autoTable({
        html: '.report-table',
        startY: 30,
        theme: 'grid',
        styles: { 
            fontSize: 8, 
            cellPadding: 3 
        },
        headStyles: { 
            fillColor: [46, 204, 113], 
            textColor: [255, 255, 255],
            fontStyle: 'bold'
        },
        didParseCell: function (data) {
            if (data.section === 'body' && [2, 3, 4].includes(data.column.index)) {
                let text = data.cell.raw.innerText || data.cell.raw.textContent;
                data.cell.text = text.replace('₹', '').trim();
            }
            if (data.section === 'body' && data.column.index === 5) {
                let status = data.cell.raw.innerText || data.cell.raw.textContent;
                data.cell.text = status.trim().toUpperCase();
            }
        }
    });

    doc.save("Sales_Report_VisionVogue.pdf");
}
</script>
</body>
</html>