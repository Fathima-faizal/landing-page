<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Professional Admin Dashboard</title>
     <link rel="stylesheet" href="/css/editOffer.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
      <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
    <div class="dashboard-container">
        <aside class="sidebar">
            <div class="nav-item ">
                <a href="/admin/dashboard">
                <i class="fas fa-th-large"></i> <span>Dashboard</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/product">
                <i class="fas fa-box"></i> <span>Product Management</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/orderManagement">
                <i class="fas fa-shopping-cart"></i> <span>Order Management</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/customer">
                <i class="fas fa-user"></i> <span>User Management</span>
                </a>
            </div>
            <div class="nav-item ">
                <a href="/admin/category">
                <i class="fas fa-layer-group"></i> <span>Category Management</span>
                </a>
            </div>
             <div class="nav-item">
                <a href="/admin/banner">
                <i class="fas fa-image"></i> <span>Banner Management</span>
                </a>
            </div>
            <div class="nav-item ">
                <a href="/admin/inventory">
                <i class="fa-solid fa-clipboard-list"></i> <span>Invetry Management</span>
                </a>
            </div>
            <hr class="nav-divider">

            <div class="nav-item">
                <a href="/admin/couponManagement">
                <i class="fas fa-ticket-alt"></i> <span>Coupon</span>
                </a>
            </div>
             <div class="nav-item">
                <a href="/admin/brand">
               <i class="fa-solid fa-tags"></i> <span>Brand</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/Reviews">
                <i class="fas fa-comment-alt"></i> <span>Review</span>
                </a>
            </div>
            <div class="nav-item active">
                <a href="/admin/offer">
                <i class="fas fa-tag"></i> <span>Offer</span>
                </a>
            </div>
           
        </aside>

        <main class="main-content">
            <header class="top-header">
                <h2>Offer Management</h2>
                <a href="/admin/logout">
                <button class="logout-top">Log out</button>
                </a>
            </header>
            <section class="content-body">
                <h3>Edit Offer</h3>
                <form id="productForm" action="/admin/editOffer/<%=offer._id%>" method="post">
                
        <div class="form-grid">
                    <div class="form-group">
                        <label>Offer Name</label>
                        <input type="text" name="offerName" placeholder="Enter the offerName"value="<%= offer.offerName%>" required>
                    </div>

                    <div class="form-group">
                        <label>Discount Percentage (%)</label>
                        <input type="number" name="discount" min="1" max="99" placeholder="Discount" value="<%= offer.discountPercentage %>" required>
                    </div>

                     <div class="form-group">
    <label>Offer Type</label>
    <select name="type" id="offerType" onchange="toggleDropdowns()" required>
        <option value="Product" <%= offer.offerType === 'Product' ? 'selected' : '' %>>Product Offer</option>
        <option value="Category" <%= offer.offerType === 'Category' ? 'selected' : '' %>>Category Offer</option>
    </select>
</div>

<div class="form-group <%= offer.offerType === 'Product' ? '' : 'hidden-group' %>" id="productGroup">
    <label>Select Product</label>
    <select name="targetId">
        <% products.forEach(p => { %>
            <option value="<%= p._id %>" <%= (offer.productId && offer.productId._id.toString() === p._id.toString()) ? 'selected' : '' %>><%= p.productName %></option>
        <% }) %>
    </select>
</div>

<div class="form-group <%= offer.offerType === 'Category' ? '' : 'hidden-group' %>" id="categoryGroup">
    <label>Select Category</label>
    <select name="targetId">
        <% categories.forEach(c => { %>
            <option value="<%= c._id %>" <%= (offer.categoryId && offer.categoryId._id.toString() === c._id.toString()) ? 'selected' : '' %>><%= c.name %></option>
        <% }) %>
    </select>
</div>
                    <div class="form-group">
                        <label>Expiry Date</label>
                        <input type="date" name="expiryDate" value="<%= offer.expiryDate.toISOString().split('T')[0] %>" required>
                    </div>
                </div>
        <div class="submit-container">
        <button type="submit" class="btn-save">Save Offer</button>
    </div>
    </div>
    
</form>
</section>
<script>
function toggleDropdowns() {
    const type = document.getElementById('offerType').value;
    const productGroup = document.getElementById('productGroup');
    const categoryGroup = document.getElementById('categoryGroup');

    if (type === 'Product') {
        productGroup.classList.remove('hidden-group');
        categoryGroup.classList.add('hidden-group');
    } else {
        productGroup.classList.add('hidden-group');
        categoryGroup.classList.remove('hidden-group');
    }
}
</script>
</body>
</html>