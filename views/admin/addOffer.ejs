<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Professional Admin Dashboard</title>
     <link rel="stylesheet" href="/css/addOffer.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
      <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
    <div class="dashboard-container">
        <aside class="sidebar">
            <div class="nav-item ">
                <a href="/admin/dashboard">
                <i class="fas fa-th-large"></i> <span>Dashboard</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/product">
                <i class="fas fa-box"></i> <span>Product Management</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/orderManagement">
                <i class="fas fa-shopping-cart"></i> <span>Order Management</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/customer">
                <i class="fas fa-user"></i> <span>User Management</span>
                </a>
            </div>
            <div class="nav-item ">
                <a href="/admin/category">
                <i class="fas fa-layer-group"></i> <span>Category Management</span>
                </a>
            </div>
             <div class="nav-item">
                <a href="/admin/banner">
                <i class="fas fa-image"></i> <span>Banner Management</span>
                </a>
            </div>
            <div class="nav-item ">
                <a href="/admin/inventory">
                <i class="fa-solid fa-clipboard-list"></i> <span>Invetry Management</span>
                </a>
            </div>
            <hr class="nav-divider">

            <div class="nav-item">
                <a href="/admin/couponManagement">
                <i class="fas fa-ticket-alt"></i> <span>Coupon</span>
                </a>
            </div>
             <div class="nav-item">
                <a href="/admin/brand">
               <i class="fa-solid fa-tags"></i> <span>Brand</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/Reviews">
                <i class="fas fa-comment-alt"></i> <span>Review</span>
                </a>
            </div>
            <div class="nav-item active">
                <a href="/admin/offer">
                <i class="fas fa-tag"></i> <span>Offer</span>
                </a>
            </div>
           
        </aside>

        <main class="main-content">
            <header class="top-header">
                <h2>Offer Management</h2>
                <a href="/admin/logout">
                <button class="logout-top">Log out</button>
                </a>
            </header>
            <section class="content-body">
                <h3>Add Offer</h3>
                <form id="productForm" action="/admin/offer" method="post">
        <div class="form-grid">
                    <div class="form-group">
                        <label>Offer Name</label>
                        <input type="text" name="offerName" placeholder="Enter the offerName" >
                        <span class="error-msg" id="name-error" style="color: red; font-size: 12px; display: none;"></span>
                    </div>

                    <div class="form-group">
                        <label>Discount Percentage (%)</label>
                        <input type="number" name="discount" min="1" max="99" placeholder="Discount" >
                        <span class="error-msg" id="discount-error" style="color: red; font-size: 12px; display: none;"></span>
                    </div>

                    <div class="form-group">
                        <label>Offer Type</label>
                        <select name="type" id="offerType" onchange="toggleDropdowns()" >
                            <option value="Product">Product Offer</option>
                            <option value="Category">Category Offer</option>
                        </select>
                    </div>

                    <div class="form-group" id="productGroup">
                        <label>Select Product</label>
                        <select name="targetId">
                            <% products.forEach(p => { %>
                                <option value="<%= p._id %>"><%= p.productName %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="form-group" id="categoryGroup" style="display: none;">
                        <label>Select Category</label>
                        <select name="targetId">
                            <% categories.forEach(c => { %>
                                <option value="<%= c._id %>"><%= c.name %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Expiry Date</label>
                        <input type="date" name="expiryDate">
                        <span class="error-msg" id="date-error" style="color: red; font-size: 12px; display: none;"></span>
                    </div>
                </div>
        <div class="submit-container">
        <button type="submit" class="btn-save">Save Offer</button>
    </div>
    </div>
    
</form>
</section>
<script>
    function toggleDropdowns() {
            const type = document.getElementById('offerType').value;
            const productGroup = document.getElementById('productGroup');
            const categoryGroup = document.getElementById('categoryGroup');

            if (type === 'Product') {
                productGroup.style.display = 'block';
                categoryGroup.style.display = 'none';
            } else {
                productGroup.style.display = 'none';
                categoryGroup.style.display = 'block';
            }
        }
        document.getElementById('productForm').addEventListener('submit', function (e) {
    clearErrors();

    const offerName = document.getElementsByName('offerName')[0].value.trim();
    const discount = document.getElementsByName('discount')[0].value;
    const expiryDate = document.getElementsByName('expiryDate')[0].value;
    let isValid = true;
    if (offerName === "") {
        displayError("name-error", "Offer Name is required!");
        isValid = false;
    } else if (offerName.length < 3) {
        displayError("name-error", "Must be at least 3 characters!");
        isValid = false;
    }
    if (discount === "" || discount <= 0 || discount >= 100) {
        displayError("discount-error", "Enter a value between 1 and 99!");
        isValid = false;
    }
    if (expiryDate === "") {
        displayError("date-error", "Please select a date!");
        isValid = false;
    } else {
        const selectedDate = new Date(expiryDate);
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        if (selectedDate < today) {
            displayError("date-error", "Date cannot be in the past!");
            isValid = false;
        }
    }

    if (!isValid) {
        e.preventDefault(); 
    }
});

function displayError(id, message) {
    const errorElement = document.getElementById(id);
    errorElement.innerText = message;
    errorElement.style.display = "block";
}

function clearErrors() {
    const errorMsgs = document.querySelectorAll('.error-msg');
    errorMsgs.forEach(msg => {
        msg.innerText = "";
        msg.style.display = "none";
    });
}
</script>
</body>
</html>