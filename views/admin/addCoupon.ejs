<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Professional Admin Dashboard</title>
     <link rel="stylesheet" href="/css/addcoupon.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
      <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
    <div class="dashboard-container">
        <aside class="sidebar">
            <div class="nav-item ">
                <a href="/admin/dashboard">
                <i class="fas fa-th-large"></i> <span>Dashboard</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/product">
                <i class="fas fa-box"></i> <span>Product Management</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/orderManagement">
                <i class="fas fa-shopping-cart"></i> <span>Order Management</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/customer">
                <i class="fas fa-user"></i> <span>User Management</span>
                </a>
            </div>
            <div class="nav-item ">
                <a href="/admin/category">
                <i class="fas fa-layer-group"></i> <span>Category Management</span>
                </a>
            </div>
           <div class="nav-item">
                <a href="/admin/banner">
                <i class="fas fa-image"></i> <span>Banner Management</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/inventory">
                <i class="fa-solid fa-clipboard-list"></i> <span>Invetry Management</span>
                </a>
            </div>
            <hr class="nav-divider">

            <div class="nav-item active">
                <a href="/admin/couponManagement">
                <i class="fas fa-ticket-alt"></i> <span>Coupon</span>
                </a>
            </div>
             <div class="nav-item">
                <a href="/admin/brand">
               <i class="fa-solid fa-tags"></i> <span>Brand</span>
                </a>
            </div>
             <div class="nav-item">
                <a href="/admin/Reviews">
                <i class="fas fa-comment-alt"></i> <span>Review</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/offer">
               <i class="fas fa-tag"></i> <span>Offers</span>
                </a>
            </div>
            
        </aside>

        <main class="main-content">
            <header class="top-header">
                <h2>Coupon Management</h2>
                <a href="/admin/logout">
                <button class="logout-top">Log out</button>
                </a>
            </header>
            <section class="content-body">
                <h3>Add Coupon</h3>
                <form id="productForm" action="/admin/couponManagement" method="post">
   <div class="form-row">
                        <div>
                            <label for="name">Name</label>
                            <input type="text" id="name" name="name" placeholder="Enter name">
                            <small id="name-error" class="error-message" style="color: red;"></small>
                        </div>
                        <div>
                        <label for="code">Coupon Code</label>
                        <input type="text" id="code" name="couponCode" placeholder="Enter Coupon code" style="text-transform: uppercase;">
                        <small id="code-error" class="error-message" style="color: red;"></small>
                       </div>
                        <div>
                            <label for="couponType">Coupon Type</label>
                            <select id="couponType" name="couponType" style="width: 100%; padding: 8px; border-radius: 4px;">
                            <option value="fixed">Fixed Amount</option>
                            <option value="percentage">Percentage</option>
                           </select>
                        </div>
                        <div>
                            <label for="Startdate">Start Date</label>
                            <input type="date" id="Startdate" name="startdate">
                            <small id="startdate-error" class="error-message" style="color: red;"></small>
                        </div>
                        <div>
                            <label for="Enddate">End Date</label>
                            <input type="date" id="Enddate" name="Enddate">
                            <small id="enddate-error" class="error-message" style="color: red;"></small>
                        </div>
                        <div>
                            <label for="Maximumprice">Minimum Price</label>
                            <input type="number" id="Minimumprice" name="Minimumprice" placeholder="Enter Minimum price">
                            <small id="maxprice-error" class="error-message" style="color: red;"></small>
                        </div>
                        <div>
                            <label for="discountPercentage">Discount Value (Amount/%)</label>
                            <input type="number" id="discountPercentage" name="discountPercentage" placeholder="Enter Value">
                            <small id="discount-error" class="error-message" style="color: red;"></small>
                        </div>
                    </div>

                    <div class="submit-container">
                        <button type="submit" class="btn-save">Save Coupon</button>
                    </div>
</form>
</section>

<script>
function displayErrorMessage(id, msg) {
    const el = document.getElementById(id);
    if (el) el.innerText = msg;
}

function clearErrorMessages() {
    document.querySelectorAll('.error-message').forEach(el => el.innerText = '');
}

function setDefaultDates() {
    const today = new Date();
    const year = today.getFullYear();
    const month = (today.getMonth() + 1).toString().padStart(2, '0');
    const day = today.getDate().toString().padStart(2, '0');
    const formattedDate = `${year}-${month}-${day}`;
    
    document.getElementById('Startdate').value = formattedDate;
    document.getElementById('Startdate').setAttribute('min', formattedDate);
    document.getElementById('Enddate').setAttribute('min', formattedDate);
}

function validateForm() {
    clearErrorMessages();
    let isValid = true;

    const name = document.getElementById('name').value.trim();
    const code = document.getElementById('code').value.trim();
    const couponType= document.getElementById('couponType').value;
    const startDate = document.getElementById('Startdate').value;
    const endDate = document.getElementById('Enddate').value;
    const minPrice = document.getElementById('Minimumprice').value;
    const discountPercentage=document.getElementById('discountPercentage').value;

    if (name === "") {
        displayErrorMessage('name-error', 'Please enter a coupon name');
        isValid = false;
    }

    if (code === "") {
        displayErrorMessage('code-error', 'Please enter a coupon code');
        isValid = false;
    }

    if (!startDate) {
        displayErrorMessage('startdate-error', 'Start date is required');
        isValid = false;
    }

    if (!endDate) {
        displayErrorMessage('enddate-error', 'End date is required');
        isValid = false;
    } else if (new Date(endDate) < new Date(startDate)) {
        displayErrorMessage('enddate-error', 'End date cannot be before start date');
        isValid = false;
    }

    if (minPrice === "" || parseFloat(minPrice) <= 0) {
        displayErrorMessage('maxprice-error', 'Minimum price must be greater than 0');
        isValid = false;
    }
    if( discountPercentage===""||parseFloat(discountPercentage)<=0){
        displayErrorMessage('maxprice-error','discount price must be greater than 0')
    }

    return isValid;
}

// 3. ഫോം സബ്മിഷൻ
document.addEventListener('DOMContentLoaded', () => {
    setDefaultDates();

    const form = document.getElementById('productForm');
    form.addEventListener('submit', async (event) => {
        event.preventDefault(); 

        if (!validateForm()) {
            return; 
        }

        const formData = {
            name: document.getElementById('name').value.trim(),
            couponCode: document.getElementById('code').value.trim(),
            startdate: document.getElementById('Startdate').value,
            Enddate: document.getElementById('Enddate').value,
            Minimumprice: document.getElementById('Minimumprice').value,
            discountPercentage:document.getElementById('discountPercentage').value
        };

        try {
            const response = await fetch('/admin/couponManagement', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(formData)
            });

            const data = await response.json();

            if (response.ok) {
                Swal.fire('Success', 'Coupon added successfully!', 'success')
                    .then(() => window.location.href = '/admin/couponManagement');
            } else {
                throw new Error(data.message || "Failed to save coupon");
            }
        } catch (error) {
            Swal.fire('Error', error.message, 'error');
        }
    });
});
</script>

</body>
</html>